---
import Layout from "../layouts/Layout.astro";

import "../styles/global.css";

import revsolar from "../assets/revsolar.png";
---

<Layout>

  <main class="text-gray-700">

    <!-- HERO -->
    <section class="px-6 py-24">

      <div
        class="mx-auto grid max-w-6xl items-center gap-16 lg:grid-cols-2"
      >

        <!-- Content -->
        <div>

          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-pink-400">
            Revolución Solar
          </p>

          <h1 class="mb-6 text-5xl font-extrabold tracking-tight md:text-6xl">
            Descubrí la energía de tu próximo año
          </h1>

          <p class="mb-8 text-lg leading-relaxed text-gray-500">
            La revolución solar permite comprender los procesos, desafíos y
            oportunidades más importantes de tu nuevo ciclo personal.
          </p>

          <a
            href="/contacto"
            class="inline-flex rounded-full bg-pink-500 px-8 py-4 text-sm font-bold uppercase tracking-wide text-white transition-all duration-300 hover:scale-105 hover:bg-pink-400"
          >
            Reservar lectura
          </a>

        </div>

        <!-- Image -->
        <div class="overflow-hidden rounded-3xl">

          <img
            src={revsolar.src}
            alt="Revolución Solar"
            class="h-full w-full object-cover"
          />

        </div>

      </div>

    </section>

    <!-- CONTENT -->
    <section class="px-6 pb-24">

      <div class="mx-auto max-w-4xl">

        <div
          class="rounded-3xl border border-white/10 bg-white/5 p-10 backdrop-blur-xl"
        >

          <h2 class="mb-6 text-3xl font-bold">
            ¿Qué incluye la lectura?
          </h2>

          <div class="space-y-6 text-lg leading-relaxed text-gray-500">

            <p>
              Analizamos las temáticas centrales del año, áreas de expansión,
              desafíos emocionales y oportunidades evolutivas.
            </p>

            <p>
              La sesión se realiza de manera personalizada y online.
            </p>

            <p>
              También se observan tránsitos importantes y activaciones
              relevantes para tu proceso actual.
            </p>

          </div>

        </div>

      </div>

    </section>

  </main>

</Layout>