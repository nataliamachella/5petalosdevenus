---
const {
  title,
  text,
  subtitle,
  img,
  href,
} = Astro.props;
---

<a
  href={href}
  class="group block h-full overflow-hidden rounded-2xl bg-white shadow-md transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-pointer"
>

  <!-- Image -->
  <div class="aspect-4/3 overflow-hidden">

    <img
      {...img}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />

  </div>

  <!-- Content -->
  <div class="p-6">

    <div class="text-sm font-semibold uppercase tracking-wide text-pink-500">
      {subtitle}
    </div>

    <h2 class="mt-2 text-xl font-bold text-black">
      {title}
    </h2>

    <p class="mt-4 leading-relaxed text-gray-500">
      {text}
    </p>

  </div>

</a>